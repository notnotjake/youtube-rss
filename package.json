{
	"name": "youtube-rss",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"f": "bun scripts/fuzzy-bun-run.ts",
		"dev": "bun run docker:check && bunx --bun vite dev",
		"dev:emails": "email dev --dir src/lib/server/email",
		"update:env": "bun scripts/pull-env.ts",
		"railway:plan": "railway environment && railway config plan",
		"railway:apply": "railway environment && railway config apply",
		"docker:start": "docker compose up -d && bun run docker:check",
		"docker:stop": "docker compose stop",
		"docker:reset": "docker compose down -v",
		"docker:check": "bun scripts/check-docker.ts",
		"url:pg": "bun scripts/copy-docker-url.ts pg",
		"db:gen": "bunx --bun drizzle-kit generate",
		"db:migrate": "bunx --bun drizzle-kit migrate",
		"db:push": "bun run docker:check && bunx --bun drizzle-kit push",
		"db:studio": "bunx --bun drizzle-kit studio",
		"test": "bun test",
		"format": "bunx --bun oxfmt",
		"check": "bun scripts/check-all.ts",
		"check:lint": "eslint . --cache --concurrency auto",
		"check:format": "bunx --bun oxfmt --check .",
		"check:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"preview": "bun run build && bunx --bun vite preview",
		"build": "bunx --bun vite build",
		"start": "bun run ./build",
		"prepare": "svelte-kit sync || echo ''"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.2",
		"@types/bun": "^1.3.14",
		"@types/node": "^26.1.0",
		"@types/react": "^19.2.17",
		"drizzle-kit": "^1.0.0-rc.4-ca0f029",
		"eslint": "^10.6.0",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"oxfmt": "^0.57.0",
		"railway": "^3.4.1",
		"svelte": "^5.56.4",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite": "^8.1.3"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@lucide/svelte": "^1.23.0",
		"@opensky/remotes": "^0.1.0",
		"@opensky/style": "^0.1.0",
		"@tabler/icons-svelte": "^3.44.0",
		"better-auth": "^1.6.23",
		"bits-ui": "^2.18.1",
		"croner": "^10.0.1",
		"drizzle-orm": "^1.0.0-rc.4-5d5b77c",
		"fast-xml-parser": "^5.9.3",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-email": "^6.6.6",
		"resend": "^6.17.1",
		"valibot": "^1.4.2"
	}
}
